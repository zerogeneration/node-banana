# Google Gemini API Key (Required for image generation and Google LLM)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- zerogen engine (BytePlus / OpenAI image / ElevenLabs generation) ---
# These three providers run through the zerogen engine over HTTP; the engine holds
# their provider keys server-side (no BYOK here). Local dev points at a loopback,
# unauthenticated engine with a single project. Only set these to override the
# defaults below.
# ZEROGEN_ENGINE_URL=http://127.0.0.1:4747   # engine base URL (default)
# ZEROGEN_PROJECT=node-banana                # engine project id/slug (default)
# ZEROGEN_AUTH_TOKEN=                         # optional bearer (cloud / auth gateway)

# OpenAI API Key (Optional - only for the OpenAI *LLM* provider; OpenAI image
# generation now runs through the zerogen engine, which holds that key)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional - only needed if using Anthropic Claude LLM provider)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Replicate API Key (Optional - only needed if using Replicate models)
# Get your API key from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# fal.ai API Key (Optional - only needed if using fal.ai models)
# Get your API key from: https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_api_key_here

# Kie.ai API Key (Optional - only needed if using Kie.ai models like Sora, Veo, Kling)
# Get your API key from: https://kie.ai/
KIE_API_KEY=your_kie_api_key_here

# WaveSpeed API Key (Optional - only needed if using WaveSpeed models)
# Get your API key from: https://wavespeed.ai/
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# BytePlus and ElevenLabs generation now runs through the zerogen engine (see the
# ZEROGEN_* settings above); their provider keys live in the engine's environment,
# not here. node-banana no longer reads BYTEPLUS_API_KEY / ARK_API_KEY /
# ELEVENLABS_API_KEY for generation.
