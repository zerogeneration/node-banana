# Example CI for node-banana. Rename to `ci.yml` to activate.
#
# Plain install + build — node-banana no longer depends on any private package,
# so no registry token / `packages: read` permission is needed.

name: CI

on:
  push:
    branches: [master]
  pull_request:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build
